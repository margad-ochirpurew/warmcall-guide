<!DOCTYPE html>
<html lang="mn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TUSS.IO - Уулзалт Товлох Скрипт</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .option-card:hover { transform: scale(1.02); }
    </style>
</head>
<body class="bg-slate-50 min-h-screen p-4 md:p-8 flex flex-col items-center">
    <div class="max-w-4xl w-full">
        <!-- Header -->
        <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="text-4xl font-extrabold text-slate-900 tracking-tighter italic">TUSS.IO</h1>
                <p class="text-slate-500 mt-1 uppercase text-xs font-bold tracking-[0.2em]">Борлуулалтын интерактив скрипт</p>
            </div>
            <div class="flex gap-2">
                <button onclick="restartCall()" class="bg-white px-4 py-2 rounded-xl shadow-sm border border-slate-200 text-xs font-bold text-slate-600 hover:bg-slate-50 transition-all flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
                    ДАХИН ЭХЛЭХ
                </button>
            </div>
        </div>

        <!-- Caller Section -->
        <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-slate-200/60 border border-slate-200 overflow-hidden flex flex-col min-h-[300px] mb-6 relative">
            <div id="status-color" class="h-2 w-full bg-blue-500 transition-colors duration-500"></div>
            
            <div class="p-8 md:p-12">
                <div class="flex items-start justify-between mb-6">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-500">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                        </div>
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Таны хэлэх текст</span>
                    </div>
                    <button onclick="copyContent()" class="text-slate-300 hover:text-blue-500 transition-colors" title="Хуулах">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    </button>
                </div>

                <div class="fade-in" id="script-container">
                    <p id="caller-text" class="text-2xl md:text-3xl text-slate-800 leading-tight font-bold tracking-tight">
                        Уншиж байна...
                    </p>
                </div>
            </div>
        </div>

        <!-- Customer Options Section -->
        <div class="mb-10">
            <h3 class="text-slate-400 text-[10px] font-black uppercase tracking-[0.3em] mb-4 text-center">Харилцагчийн хариулт (Сонгох)</h3>
            <div id="options-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Buttons generated here -->
            </div>
        </div>

        <!-- Footer Tips -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 opacity-60">
            <div class="bg-white p-4 rounded-2xl border border-slate-200 text-center">
                <p class="text-[10px] font-bold text-slate-400 uppercase">Зорилго</p>
                <p class="text-sm font-bold text-slate-700 italic">Уулзалт товлох</p>
            </div>
            <div class="bg-white p-4 rounded-2xl border border-slate-200 text-center">
                <p class="text-[10px] font-bold text-slate-400 uppercase">Төлөв</p>
                <p id="call-status" class="text-sm font-bold text-slate-700">Яриа үргэлжилж байна</p>
            </div>
            <div class="bg-white p-4 rounded-2xl border border-slate-200 text-center">
                <button onclick="goBack()" id="back-btn" class="text-[10px] font-bold text-blue-500 uppercase disabled:opacity-30">← Өмнөх алхам руу буцах</button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="toast" class="fixed bottom-8 bg-slate-900 text-white px-6 py-3 rounded-full shadow-2xl opacity-0 transition-all pointer-events-none font-bold text-sm">
        Хуулагдлаа!
    </div>

    <script>
        const dialogue = {
            'start': {
                text: "Сайн байна уу, TUSS.IO-оос ярьж байна. Та манай вэбээр зочилж демо ашиглах сонирхлоо илэрхийлсэн байна. Танд энэ талаар дэлгэрэнгүй мэдээлэл өгөхөд тохиромжтой цаг мөн үү?",
                color: "#3b82f6",
                options: [
                    { label: "Тийм ээ, сонсож байна.", next: 'intro_value' },
                    { label: "Танайх яг юу хийдэг вэ?", next: 'detailed_info' },
                    { label: "Одоо завгүй байна.", next: 'busy_offer_mail' }
                ]
            },
            'detailed_info': {
                text: "Бид байгууллагын системчлэлийн платформыг хөгжүүлэгч юм. Бид стратегийн төлөвлөлт, гүйцэтгэлийн удирдлага, дотоод аудит болон ISO стандартыг датанд суурилан автоматжуулдаг. Энгийнээр хэлбэл, удирдлагын шийдвэр гаргалтыг бодит шинжилгээнд үндэслэхэд тусалдаг.",
                color: "#6366f1",
                options: [
                    { label: "Ойлгомжтой, цаашаа ярья.", next: 'intro_value' },
                    { label: "Зөвхөн мэйлээр мэдээлэл авъя.", next: 'end_only_mail' }
                ]
            },
            'intro_value': {
                text: "Бид танай байгууллагын үйл ажиллагааны онцлогт тохирсон шийдлийг гаргахын тулд богино хэмжээний уулзалт (15-20 минут) хийвэл илүү үр дүнтэй байдаг юм. Хэзээ уулзах боломжтой вэ?",
                color: "#a855f7",
                options: [
                    { label: "За, уулзалт товлоё.", next: 'confirm_meeting' },
                    { label: "Уулзахгүй, зөвхөн демо авъя.", next: 'why_meeting' },
                    { label: "Уулзалт хэрэггүй, мэдээлэл авъя.", next: 'end_only_mail' }
                ]
            },
            'why_meeting': {
                text: "Ойлголоо. Гэхдээ демо ашиглахаас өмнө та өөрийн сайн мэдэхгүй программаа шууд ашиглах гэж байгаа учраас бид заавар зөвлөгөө өгөх нь илүү үр дүнтэй байх болов уу гэж бодож байна. Та ямар ч байсан нэг уулзаад үзэх үү?",
                color: "#f59e0b",
                options: [
                    { label: "За за, тэгвэл уулзая.", next: 'confirm_meeting' },
                    { label: "Үгүй ээ, зөвхөн демог нь авъя.", next: 'direct_demo_open' }
                ]
            },
            'confirm_meeting': {
                text: "Уулзалт товлосондоо баяртай байна. Би таны мэйл рүү уулзалтын урилга болон программыг ашиглахад хэрэгтэй видео заавар бүхий хөтөчийг урьдчилж илгээлээ. Уулзалтаар илүү дэлгэрэнгүй ярилцъя. Баяртай.",
                color: "#10b981",
                isEnd: true,
                options: []
            },
            'direct_demo_open': {
                text: "За тэгвэл би танд зориулж демо хувилбарыг нь нээж өгье. Мөн танд программ ашиглахад хэрэгтэй видео заавар бүхий хөтөчийг мэйлээр илгээлээ. Демог бүрэн нээхэд шаардлагатай зарим мэдээллийг мэйлээр лавлаж асуух тул та зав чөлөөгөөрөө хариу өгөөрэй. Баяртай.",
                color: "#10b981",
                isEnd: true,
                options: []
            },
            'busy_offer_mail': {
                text: "Ойлголоо. Тэгвэл би танд дэлгэрэнгүй мэдээлэл болон видео заавар бүхий хөтөчийг мэйлээр хүргүүлчихье. Та завтай үедээ танилцаад асуух зүйл гарвал эргээд холбогдоорой. Баярлалаа.",
                color: "#64748b",
                isEnd: true,
                options: []
            },
            'end_only_mail': {
                text: "Мэдээж хэрэг. Би таны мэйл рүү TUSS.IO-ийн дэлгэрэнгүй танилцуулга болон видео заавруудыг одоо явуулчихлаа. Та танилцаад асуух зүйл гарвал хэзээ ч холбогдож болно. Баярлалаа, өдрийг сайхан өнгөрүүлээрэй.",
                color: "#64748b",
                isEnd: true,
                options: []
            }
        };

        let currentId = 'start';
        let history = [];

        function restartCall() {
            history = [];
            currentId = 'start';
            updateUI();
        }

        function selectOption(nextId) {
            history.push(currentId);
            currentId = nextId;
            updateUI();
        }

        function goBack() {
            if (history.length > 0) {
                currentId = history.pop();
                updateUI();
            }
        }

        function copyContent() {
            const text = dialogue[currentId].text;
            const el = document.createElement('textarea');
            el.value = text;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);

            const toast = document.getElementById('toast');
            toast.style.opacity = '1';
            setTimeout(() => toast.style.opacity = '0', 2000);
        }

        function updateUI() {
            const node = dialogue[currentId];
            const container = document.getElementById('script-container');
            container.classList.remove('fade-in');
            void container.offsetWidth;
            container.classList.add('fade-in');

            document.getElementById('caller-text').innerText = node.text;
            document.getElementById('status-color').style.backgroundColor = node.color;
            document.getElementById('call-status').innerText = node.isEnd ? "Дуудлага дууссан" : "Яриа үргэлжилж байна";
            document.getElementById('back-btn').disabled = history.length === 0;

            const optionsGrid = document.getElementById('options-grid');
            optionsGrid.innerHTML = '';
            
            if (node.options.length > 0) {
                node.options.forEach(opt => {
                    const btn = document.createElement('button');
                    btn.onclick = () => selectOption(opt.next);
                    btn.className = "option-card group bg-white border-2 border-slate-100 p-5 rounded-2xl text-left shadow-sm hover:border-blue-500 hover:shadow-lg transition-all duration-300 flex items-center justify-between";
                    btn.innerHTML = `
                        <span class="text-sm font-bold text-slate-600 group-hover:text-blue-600">${opt.label}</span>
                        <div class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-300 group-hover:bg-blue-50 group-hover:text-blue-500">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                        </div>
                    `;
                    optionsGrid.appendChild(btn);
                });
            } else if (node.isEnd) {
                optionsGrid.innerHTML = `
                    <div class="col-span-full py-8 text-center text-slate-400 font-bold border-2 border-dashed border-slate-200 rounded-3xl uppercase tracking-widest">
                        Харилцаа дууслаа
                    </div>
                `;
            }
        }

        window.onload = updateUI;
    </script>
</body>
</html>
